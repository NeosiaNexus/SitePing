{
  "name": "siteping",
  "private": true,
  "description": "Client feedback widget — self-hosted, DOM-anchored annotations for websites",
  "homepage": "https://siteping.dev",
  "type": "module",
  "author": "neosianexus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeosiaNexus/SitePing.git"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "clean": "turbo run clean",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.61.1",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.9.5",
    "@vitest/coverage-istanbul": "^3.2.7",
    "jsdom": "29.1.1",
    "tsup": "^8.5.1",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
